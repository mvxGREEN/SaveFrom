<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="@dimen/spacing_med"
    android:background="@null">

    <!-- PLAY/PAUSE -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/player_play_pause"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_margin="@dimen/spacing_med"
        android:contentDescription="@string/cont_desc_player_control_btn"
        android:src="@drawable/ic_play"
        android:backgroundTint="@color/shadowInverse"
        android:tint="@color/white"
        app:rippleColor="@color/shadowDarker"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/player_play_pause"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginHorizontal="@dimen/spacing_med"
        android:orientation="vertical">

        <TextView
            android:id="@+id/item_file_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppTitle"
            android:textColor="@color/shadowInverseDark"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/item_file_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppSubtitle"
            android:textColor="@color/shadowInverse"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>