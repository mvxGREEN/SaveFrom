<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:padding="@dimen/spacing_med"
    android:background="@color/colorPrimaryDark">

    <!-- APP BAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="32dp"
        android:theme="@style/AppTheme.AppBarOverlay"
        android:background="@null">

        <!-- TOOLBAR -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/height_toolbar"
            app:buttonGravity="top"
            app:maxButtonHeight="56dp"
            android:paddingHorizontal="@dimen/spacing_small"
            app:menu="@menu/main"
            app:popupTheme="@style/AppTheme.NoActionBar"
            android:background="@null"
            app:titleTextColor="@color/shadowInvisible"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- LOADING OVERLAY -->
    <LinearLayout
        android:id="@+id/loading_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:orientation="vertical"
        android:visibility="invisible"
        android:gravity="center"
        android:elevation="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progress_ring"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:indeterminateTint="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/progress_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/loading"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- VERTICAL SCROLL -->
    <ScrollView
        android:id="@+id/main_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/appbar"
        android:orientation="vertical">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/main_vertical_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/searchContainer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginVertical="16dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="@drawable/bg_search_bar"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="4dp"
                    app:layout_constraintTop_toBottomOf="@+id/appBarLayout">

                    <EditText
                        android:id="@+id/etMainInput"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/paste_url"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:inputType="textUri"
                        android:maxLines="1" />

                    <ImageButton
                        android:id="@+id/btnClear"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/clear_button"
                        android:src="@drawable/ic_close"
                        android:visibility="invisible"
                        app:tint="@color/text_secondary"
                        tools:visibility="visible"/>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="@color/divider" />

                    <ImageButton
                        android:id="@+id/btnPaste"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_paste"
                        app:tint="@color/selector_paste_tint"
                        android:onClick="onPasteClick"/>
                </LinearLayout>

                <!-- PREVIEW CARD -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/preview_card"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/size_preview_card"
                    app:layout_constraintTop_toBottomOf="@id/searchContainer"
                    android:layout_marginHorizontal="8dp"
                    app:cardBackgroundColor="@color/shadowInverseLight"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="@dimen/elevation_low"
                    android:alpha="0.0">

                    <!-- WEBVIEW -->
                    <WebView
                        android:id="@+id/preview_webview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:elevation="@dimen/elevation_middle"
                        android:contentDescription="@string/cont_desc_preview"
                        android:visibility="invisible"/>

                    <!-- THUMBNAIL -->
                    <ImageView
                        android:id="@+id/img_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:elevation="@dimen/elevation_middle"
                        android:contentDescription="@string/cont_desc_preview"
                        android:visibility="visible" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/container_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:elevation="@dimen/elevation_middle"
                        android:contentDescription="@string/cont_desc_preview">

                        <!-- DOWNLOADING OVERLAY -->
                        <FrameLayout
                            android:id="@+id/overlay_downloading"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#99000000"
                            android:visibility="invisible">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ProgressBar
                                    android:id="@+id/progress_ring_dlr"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="160dp"
                                    android:layout_height="wrap_content"
                                    android:elevation="8dp"
                                    android:indeterminate="true"
                                    android:progressTint="?attr/colorPrimary" />

                                <TextView
                                    android:id="@+id/dl_progress_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="@string/downloading"
                                    android:textColor="@android:color/white"
                                    android:textSize="16sp"
                                    android:textAlignment="center"/>
                            </LinearLayout>
                        </FrameLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.cardview.widget.CardView>

                <!-- DOWNLOADER -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/downloader_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="16dp"
                    android:layout_marginHorizontal="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardElevation="2dp"
                    android:padding="8dp"
                    app:layout_constraintTop_toBottomOf="@+id/preview_card"
                    android:alpha="0.0">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="8dp">

                        <!-- RESOLUTION SPINNER -->
                        <Spinner
                            android:id="@+id/res_spinner"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="4dp"
                            android:paddingEnd="32dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            android:background="@drawable/bg_spinner_with_arrow" />

                        <!-- TITLE -->
                        <TextView
                            android:id="@+id/preview_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:layout_margin="8dp"
                            app:layout_constraintStart_toEndOf="@+id/res_spinner"
                            app:layout_constraintEnd_toStartOf="@id/action_container"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toTopOf="@+id/preview_subtitle"
                            app:layout_constraintVertical_chainStyle="packed"/>

                        <!-- SUBTITLE -->
                        <TextView
                            android:id="@+id/preview_subtitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="?android:attr/textColorSecondary"
                            android:textSize="14sp"
                            android:layout_marginHorizontal="16dp"
                            android:layout_marginTop="4dp"
                            android:visibility="gone"
                            app:layout_constraintStart_toEndOf="@+id/res_spinner"
                            app:layout_constraintEnd_toStartOf="@id/action_container"
                            app:layout_constraintTop_toBottomOf="@+id/preview_title"
                            app:layout_constraintBottom_toBottomOf="parent"/>

                        <FrameLayout
                            android:id="@+id/action_container"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:elevation="8dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent">

                            <ImageButton
                                android:id="@+id/dl_btn"
                                android:layout_width="48dp"
                                android:layout_height="match_parent"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@drawable/ic_download"
                                app:tint="?attr/colorOnSurface"
                                android:contentDescription="Download" />

                            <ImageButton
                                android:id="@+id/share_btn"
                                android:layout_width="48dp"
                                android:layout_height="match_parent"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@drawable/ic_share_40"
                                app:tint="?attr/colorOnSurface"
                                android:alpha="1.0"
                                android:visibility="invisible"
                                android:contentDescription="Share button" />
                        </FrameLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <!-- FILE / HINT HOLDER -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/file_hint_holder"
                    android:elevation="@dimen/elevation_top"
                    android:layout_margin="@dimen/spacing_med"
                    android:background="@drawable/bg_rounded_black_stroke_inv"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/preview_card"
                    android:visibility="gone"/>

                <!-- PERMISSION HOLDER -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/permission_holder"
                    android:elevation="@dimen/elevation_top"
                    android:paddingVertical="8dp"
                    android:layout_marginHorizontal="@dimen/spacing_med"
                    android:layout_margin="@dimen/spacing_med"
                    android:background="@drawable/bg_rounded_black_stroke_inv"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/preview_card"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:text="Run in background:"
                        android:textColor="@color/shadowInverseDark"
                        android:textSize="16sp"
                        android:layout_marginVertical="8dp"
                        android:layout_marginStart="16dp"/>

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:background="@color/shadowInverseDark"
                        android:text="Enable"
                        android:textColor="@color/shadowDarker"
                        android:layout_margin="8dp"
                        android:onClick="onEnableBackgroundClicked"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>